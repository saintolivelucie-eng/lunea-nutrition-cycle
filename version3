function switchScsCard(key, card) {
  /* Reset all flip cards in the currently active panel first */
  var activePanel = document.querySelector('.scs-panel.active');
  if (activePanel) {
    activePanel.querySelectorAll('.scs-flip-inner').forEach(function(fi) {
      fi.classList.remove('flipped');
    });
  }
  /* Deactivate all sym cards */
  document.querySelectorAll('.scs-sym-card').forEach(function(c) { c.classList.remove('active'); });
  /* Hide all panels */
  document.querySelectorAll('.scs-panel').forEach(function(p) { p.classList.remove('active'); });
  /* Activate selected */
  card.classList.add('active');
  var t = document.getElementById('scs-' + key);
  if (t) t.classList.add('active');
}

function toggleScsFlip(gridId, index) {
  var grid = document.getElementById(gridId);
  if (!grid) return;
  var flips = grid.querySelectorAll('.scs-flip-inner');
  var target = flips[index];
  if (!target) return;
  var isFlipped = target.classList.contains('flipped');
  /* Reset all in this grid */
  flips.forEach(function(f) { f.classList.remove('flipped'); });
  /* Toggle target */
  if (!isFlipped) target.classList.add('flipped');
}


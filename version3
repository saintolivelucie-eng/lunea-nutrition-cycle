/* ── DESKTOP FLIP CARDS for symptoms ── */
.scs-flip-grid {
  display: none; /* shown only on desktop via media query */
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  perspective: 1200px;
  margin-bottom: 2rem;
}
.scs-flip-wrap {
  height: 420px;
  perspective: 1200px;
}
.scs-flip-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.55s cubic-bezier(.4,0,.2,1);
  cursor: pointer;
}
.scs-flip-inner.flipped {
  transform: rotateY(180deg);
}
.scs-flip-front,
.scs-flip-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 22px;
  padding: 1.8rem;
  overflow-y: auto;
}
.scs-flip-back {
  transform: rotateY(180deg);
}
.scs-flip-front.scs-before {
  background: linear-gradient(145deg,#F0FAF0,#FAFFF7);
  border: 1px solid #C8D9A5;
}
.scs-flip-front.scs-during {
  background: linear-gradient(145deg,#FEF5F7,#FFF8FB);
  border: 1px solid #F2C4CE;
}
.scs-flip-back {
  background: var(--warm-white);
  border: 1px solid var(--beige);
}
.scs-flip-tap-hint {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--taupe);
  opacity: 0.6;
  margin-top: 0.8rem;
  text-align: center;
  display: block;
}
.scs-flip-back-close {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 0.8rem;
}
.scs-flip-back-close button {
  background: rgba(61,46,46,0.07);
  border: none;
  border-radius: 50%;
  width: 28px; height: 28px;
  cursor: pointer;
  font-size: 0.8rem;
  color: var(--taupe);
  display: flex; align-items: center; justify-content: center;
}

/* Desktop: show flip grid, hide the stacked when-grid */
@media(min-width:769px) {
  .scs-flip-grid { display: grid; }
  .scs-panel .scs-when-grid { display: none; }
}
/* Mobile: hide flip grid, show stacked */
@media(max-width:768px) {
  .scs-flip-grid { display: none !important; }

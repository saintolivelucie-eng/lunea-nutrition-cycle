function calcPhase(){var input=document.getElementById('cycleStartDate');var result=document.getElementById('phaseResult');if(!input.value){result.innerHTML='<span style="color:var(--taupe)">Pick a date above to find your phase ↑</span>';return;}var start=new Date(input.value);var today=new Date();today.setHours(0,0,0,0);start.setHours(0,0,0,0);var diff=Math.floor((today-start)/(1000*60*60*24));if(diff<0){result.innerHTML='<span style="color:var(--taupe)">That date is in the future — did you mean a past date?</span>';return;}var cycleLen=28;var day=(diff%cycleLen)+1;var phase,color,emoji,msg;if(day>=1&&day<=5){phase='Menstrual';color='#D4788A';emoji='🌑';msg='Rest, warmth, iron-rich foods. Give yourself permission to slow down.';}else if(day>=6&&day<=13){phase='Follicular';color='#7A9E76';emoji='🌱';msg='Energy is rising. Your gut loves probiotics right now.';}else if(day>=14&&day<=16){phase='Ovulatory';color='#C09040';emoji='🌕';msg='Peak vitality! Antioxidants and raw veggies match your energy.';}else{phase='Luteal';color='#8070A8';emoji='🍂';msg='Progesterone is in charge. Magnesium and slow carbs are your allies.';}result.innerHTML='<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap"><span style="font-size:1.8rem">'+emoji+'</span><div><p style="font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;color:'+color+';margin:0">Day '+day+' of 28</p><p style="font-family:\'Cormorant Garamond\',serif;font-size:1.3rem;font-weight:500;color:var(--brown);margin:0.1rem 0">You\'re in your <strong style="color:'+color+'">'+phase+' phase</strong></p><p style="font-size:0.8rem;color:var(--taupe);margin:0.2rem 0">'+msg+'</p><button onclick="showPhase(\''+phase.toLowerCase()+'\')" style="margin-top:0.5rem;background:'+color+';color:white;border:none;border-radius:100px;padding:0.4rem 1rem;font-family:\'Jost\',sans-serif;font-size:1rem;letter-spacing:0.08em;cursor:pointer">See my phase guide →</button></div></div>';}

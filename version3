document.querySelectorAll('.rfp-btn').forEach(function(btn){
  btn.addEventListener('click',function(){
    var type=btn.dataset.filter;var value=btn.dataset.value;
    var group=btn.closest('[data-max]');var max=parseInt(group.dataset.max);
    if(type==='meal'||type==='phase'){
      if(filterState[type]===value){filterState[type]=null;btn.classList.remove('selected');}
      else{group.querySelectorAll('.rfp-btn').forEach(function(b){b.classList.remove('selected');});filterState[type]=value;btn.classList.add('selected');}
    }else{
      var arr=filterState[type];var idx=arr.indexOf(value);
      if(idx>-1){arr.splice(idx,1);btn.classList.remove('selected');}
      else if(arr.length<max){arr.push(value);btn.classList.add('selected');}
      group.querySelectorAll('.rfp-btn:not(.selected)').forEach(function(b){b.classList.toggle('at-limit',arr.length>=max);});
    }
  });
});


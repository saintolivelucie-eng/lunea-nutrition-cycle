const filterState={meal:null,phase:null,nutrient:[],condition:[],symptom:[]};

function scoreRecipe(r){
  var f = filterState;
  var hasAnyFilter = f.meal || f.phase || f.nutrient.length || f.condition.length || f.symptom.length;
  if(!hasAnyFilter) return 1;

  /* Hard filters — must match */
  if(f.meal  && r.meal  !== f.meal)  return -1;
  if(f.phase && r.phase !== f.phase) return -1;

  var score = 0;

  /* Nutrient filter — independent block */
  /* ↓ You can delete from here to END-NUTRIENT without affecting symptom logic */
  f.nutrient.forEach(function(n){ if(r.nutrients.includes(n)) score += 2; });
  if(f.nutrient.length && score === 0 && !f.symptom.length) return -1;
  /* END-NUTRIENT ↑ */

  /* Symptom filter — independent block */
  var symptomScore = 0;
  f.symptom.forEach(function(sym){
    var mapped = SYMPTOM_NUTRIENT_MAP[sym] || [];
    var hits = mapped.filter(function(n){ return r.nutrients.includes(n); });
    if(hits.length) symptomScore += hits.length;
  });
  if(f.symptom.length){
    if(symptomScore === 0) return -1;
    score += symptomScore * 2;
  }

  /* Condition filter */
  f.condition.forEach(function(c){ if(r.conditions.includes(c)) score += 1; });
  if(f.condition.length && score === 0) return -1;

  return score || 1;
}


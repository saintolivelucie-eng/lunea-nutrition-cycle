  document.body.style.overflow = 'hidden';
}

function closeFoodPopup(event) {
  if (event.target === document.getElementById('foodPopup')) closeFoodPopupDirect();
}

function closeFoodPopupDirect() {
  var m = document.getElementById('foodPopup');
  if (m) m.classList.remove('open');
  document.body.style.overflow = '';
}
  
/* Initial render */
renderRecipes();
</script>
</body>
</html>
